{
  "name": "bgs",
  "version": "1.0.0",
  "main": "api/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nodemon api/index.js",
    "start": "node api/index.js",
    "build": "npm install && cd client && npm install && npm run build",
    "postinstall": "if [ -d client ]; then cd client && npm install; else echo 'Pasta client nao encontrada, continuando...'; fi",
    "clean": "rm -rf node_modules client/node_modules client/dist"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.17.0",
    "mongoose": "^8.15.2",
    "nodemailer": "^7.0.3",
    "nodemon": "^3.1.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19"
  }
}